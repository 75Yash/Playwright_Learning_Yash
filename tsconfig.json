{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020", "DOM"],
    "strict": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "noEmit": true,
    "types": ["node", "@playwright/test"]
  },
  "include": [
    "tests",
    "pages",
    "utils",
    "features",
    "fixtures",
    "*.ts"
  ],
  "exclude": [
    "node_modules",
    "playwright-report",
    "reports",
    "test-results"
  ]
}
